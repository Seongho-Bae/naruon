{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-models/gpt-5",
  "small_model": "github-models/gpt-5-mini",
  "enabled_providers": ["github-models"],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["npx", "-y", "@colbymchenry/codegraph@0.9.9", "serve", "--mcp"],
      "enabled": true
    }
  },
  "provider": {
    "github-models": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GitHub Models",
      "options": {
        "baseURL": "https://models.github.ai/inference",
        "apiKey": "{env:STRIX_GITHUB_MODELS_TOKEN}"
      },
      "models": {
        "gpt-5": {
          "name": "OpenAI GPT-5",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-5-mini": {
          "name": "OpenAI GPT-5 mini",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-5-nano": {
          "name": "OpenAI GPT-5 nano",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  }
}
